<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lottery.Views.StudentV"
             xmlns:ViewModels="clr-namespace:Lottery.ViewModels"
             x:DataType="ViewModels:StudentVM">

    <Frame Padding="10,8" StyleClass="student-row">
        <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">

                <Label Text="{Binding IdNr}"
                       StyleClass="student-id"/>

            <Label Grid.Column="1"
                   Text="{Binding Name}"
                   StyleClass="student-name"/>

            <CheckBox Grid.Column="2"
                      IsChecked="{Binding Present}" />

        </Grid>
    </Frame>

</ContentView>
